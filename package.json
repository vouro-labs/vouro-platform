{
  "name": "vouro-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "VOURO: Solana-based Proof-to-Earn platform with interactive voxel world",
  "scripts": {
    "dev": "concurrently -n \"web,api\" -c \"cyan,green\" \"pnpm --filter web dev\" \"pnpm --filter api dev\"",
    "build": "pnpm -r build",
    "start": "pnpm --filter api start",
    "test": "vitest run"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "bufferutil",
      "utf-8-validate"
    ]
  }
}
